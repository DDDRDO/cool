local TrackedThemeLabels = {}
local TrackedThemeButtons = {}

local function SyncThemeColors(newColor)
	CurrentThemeColor = newColor
	UIStroke.Color = newColor
	TitleBar.TextColor3 = newColor
	CircleStroke.Color = newColor
	Container.ScrollBarImageColor3 = newColor
	FOVCircle.Color = newColor
	if mobileAimingActive then
		MobileAimCircle.TextColor3 = newColor
		AimCircleStroke.Color = newColor
	end
	for _, item in pairs(TrackedThemeLabels) do
		if item.Instance then item.Instance.BackgroundColor3 = newColor end
	end
	for _, item in pairs(TrackedThemeButtons) do
		if item.Instance and item.IsOn() then item.Instance.BackgroundColor3 = newColor end
	end
end

-- Slider Constructor
local function CreateSlider(text, min, max, default, callback)
	local sliderFrame = Instance.new("Frame", Container)
	sliderFrame.Size = UDim2.new(1, 0, 0, 50)
	sliderFrame.BackgroundTransparency = 1
	
	local label = Instance.new("TextLabel", sliderFrame)
	label.Size = UDim2.new(1, 0, 0, 20)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.Gotham
	label.TextSize = 12
	label.TextColor3 = Color3.fromRGB(220, 220, 220)
	label.TextXAlignment = Enum.TextXAlignment.Left
	
	local track = Instance.new("Frame", sliderFrame)
	track.Size = UDim2.new(1, 0, 0, 6)
	track.Position = UDim2.new(0, 0, 0, 30)
	track.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
	track.BorderSizePixel = 0
	Instance.new("UICorner", track)
	
	local fill = Instance.new("Frame", track)
	fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
	fill.BackgroundColor3 = CurrentThemeColor
	fill.BorderSizePixel = 0
	Instance.new("UICorner", fill)
	
	table.insert(TrackedThemeLabels, {Instance = fill})
	
	local trigger = Instance.new("TextButton", track)
	trigger.Size = UDim2.new(0, 14, 0, 14)
	trigger.Position = UDim2.new((default - min) / (max - min), -7, 0.5, -7)
	trigger.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	trigger.Text = ""
	Instance.new("UICorner", trigger)
	
	local function update(input)
		local scale = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local value = math.floor((min + (scale * (max - min))) * 100) / 100
		fill.Size = UDim2.new(scale, 0, 1, 0)
		trigger.Position = UDim2.new(scale, -7, 0.5, -7)
		label.Text = text .. " : " .. tostring(value)
		callback(value)
	end
	
	local sliding = false
	trigger.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = true end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			update(input)
		end
	end)
	
	label.Text = text .. " : " .. tostring(default)
	callback(default)
end

local function CreateToggleButton(text, defaultState, callback)
	local btn = Instance.new("TextButton", Container)
	btn.Size = UDim2.new(1, 0, 0, 38)
	btn.BackgroundColor3 = defaultState and CurrentThemeColor or Color3.fromRGB(35, 35, 45)
	btn.Text = text .. " : " .. (defaultState and "ON" or "OFF")
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 13
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	
	local state = defaultState
	table.insert(TrackedThemeButtons, {
		Instance = btn,
		IsOn = function() return state end
	})
	
	btn.MouseButton1Click:Connect(function()
		state = not state
		btn.BackgroundColor3 = state and CurrentThemeColor or Color3.fromRGB(35, 35, 45)
		btn.Text = text .. " : " .. (state and "ON" or "OFF")
		callback(state)
	end)
	return btn
end

