-- ACCURATE JUMP POWER / JUMP HEIGHT CALIBRATION SLIDER
CreateSlider("LocalPlayer Jump Height", 7, 100, 7, function(v)
	if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
		local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		
		-- Alters JumpHeight safely for modern games
		hum.JumpHeight = v
		
		-- Alters older JumpPower properties automatically in case the game configuration relies on it
		if v == 7 then
			hum.JumpPower = Settings.DefaultJumpPower
		else
			-- Scale physics calculation to prevent excessive over-clamping
			hum.UseJumpPower = true
			hum.JumpPower = math.clamp(v * 7.5, 50, 300) 
		end
	end
end)

