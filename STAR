-- Aimbot Loops
local desktopAiming = false
UserInputService.InputBegan:Connect(function(input)
	if input.KeyCode == Settings.AimKey then desktopAiming = true end
end)
UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Settings.AimKey then desktopAiming = false end
end)

RunService.RenderStepped:Connect(function()
	FOVCircle.Position = UserInputService:GetMouseLocation()
	FOVCircle.Radius = Settings.FOV
	FOVCircle.Visible = Settings.AimbotEnabled and MainFrame.Visible
	
	if Settings.AimbotEnabled and (desktopAiming or mobileAimingActive) then
		local target = GetClosestPlayer()
		if target and target.Character then
			local actualPart = Settings.AimPart == "Torso" and (target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("Torso")) or target.Character:FindFirstChild("Head")
			if actualPart then
				local currentCFrame = Camera.CFrame
				local targetCFrame = CFrame.new(currentCFrame.Position, actualPart.Position)
				Camera.CFrame = currentCFrame:Lerp(targetCFrame, 1 - Settings.Smoothness)
			end
		end
	end
end)

-- Chams Highlight Controller
local VisualsStorage = {}
local function HandlePlayerVisuals(player)
	if player == LocalPlayer then return end
	local tracer = Drawing.new("Line")
	tracer.Thickness = 1.5
	tracer.Visible = false
	
	local function clearHighlight(char)
		if char and char:FindFirstChild("ESP_Highlight") then char.ESP_Highlight:Destroy() end
	end

	local connection
	connection = RunService.RenderStepped:Connect(function()
		local char = player.Character
		if not player.Parent or not VisualsStorage[player] then
			tracer:Destroy()
			if char then clearHighlight(char) end
			connection:Disconnect()
			return
		end
		
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		local teamColor = player.TeamColor and player.TeamColor.Color or Color3.fromRGB(255, 255, 255)
		
		if hrp and hum and hum.Health > 0 then
			local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
			if onScreen and Settings.TracersEnabled then
				tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
				tracer.To = Vector2.new(screenPos.X, screenPos.Y)
				tracer.Color = teamColor
				tracer.Visible = true
			else
				tracer.Visible = false
			end
			
			if Settings.HighlightEnabled then
				local hl = char:FindFirstChild("ESP_Highlight")
				if not hl then
					hl = Instance.new("Highlight", char)
					hl.Name = "ESP_Highlight"
				end
				hl.FillColor = teamColor
				hl.OutlineColor = Color3.fromRGB(255, 255, 255)
				hl.FillTransparency = 0.4
				hl.Enabled = true
			else
				clearHighlight(char)
			end
		else
			tracer.Visible = false
			clearHighlight(char)
		end
	end)
	VisualsStorage[player] = {Tracer = tracer}
end

Players.PlayerAdded:Connect(HandlePlayerVisuals)
for _, p in pairs(Players:GetPlayers()) do HandlePlayerVisuals(p) end
Players.PlayerRemoving:Connect(function(p) VisualsStorage[p] = nil end)
