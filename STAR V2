-- Horizontal Optimized Slider Component
local function CreateSlider(text, min, max, default, callback)
	local sliderFrame = Instance.new("Frame", Container)
	sliderFrame.BackgroundTransparency = 1
	
	local label = Instance.new("TextLabel", sliderFrame)
	label.Size = UDim2.new(1, 0, 0, 18)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamMedium
	label.TextSize = 11
	label.TextColor3 = Color3.fromRGB(220, 220, 225)
	label.TextXAlignment = Enum.TextXAlignment.Left
	
	local track = Instance.new("Frame", sliderFrame)
	track.Size = UDim2.new(1, 0, 0, 4)
	track.Position = UDim2.new(0, 0, 0, 28)
	track.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
	track.BorderSizePixel = 0
	Instance.new("UICorner", track)
	
	local fill = Instance.new("Frame", track)
	fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
	fill.BackgroundColor3 = CurrentThemeColor
	fill.BorderSizePixel = 0
	Instance.new("UICorner", fill)
	
	table.insert(TrackedThemeLabels, {Instance = fill})
	
	local trigger = Instance.new("TextButton", track)
	trigger.Size = UDim2.new(0, 12, 0, 12)
	trigger.Position = UDim2.new((default - min) / (max - min), -6, 0.5, -6)
	trigger.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	trigger.Text = ""
	Instance.new("UICorner", trigger)
	local trigStroke = Instance.new("UIStroke", trigger)
	trigStroke.Color = Color3.fromRGB(0,0,0)
	trigStroke.Thickness = 1.2
	
	local function update(input)
		local scale = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local value = math.floor((min + (scale * (max - min))) * 100) / 100
		fill.Size = UDim2.new(scale, 0, 1, 0)
		trigger.Position = UDim2.new(scale, -6, 0.5, -6)
		label.Text = text .. " ➔ " .. tostring(value)
		callback(value)
	end
	
	local sliding = false
	trigger.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = true end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			update(input)
		end
	end)
	
	label.Text = text .. " ➔ " .. tostring(default)
	callback(default)
end

-- Wide Optimized Toggle Component
local function CreateToggleButton(text, defaultState, callback)
	local btn = Instance.new("TextButton", Container)
	btn.BackgroundColor3 = defaultState and CurrentThemeColor or Color3.fromRGB(18, 18, 26)
	btn.Text = "  " .. text .. " : " .. (defaultState and "ON" or "OFF")
	btn.TextColor3 = defaultState and Color3.fromRGB(10, 10, 14) or Color3.fromRGB(200, 200, 210)
	btn.Font = Enum.Font.GothamMedium
	btn.TextSize = 11
	btn.TextXAlignment = Enum.TextXAlignment.Left
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
	
	local btnStroke = Instance.new("UIStroke", btn)
	btnStroke.Color = Color3.fromRGB(35, 35, 48)
	btnStroke.Thickness = 1
	
	local state = defaultState
	table.insert(TrackedThemeButtons, {
		Instance = btn,
		IsOn = function() return state end
	})
	
	btn.MouseButton1Click:Connect(function()
		state = not state
		btn.BackgroundColor3 = state and CurrentThemeColor or Color3.fromRGB(18, 18, 26)
		btn.TextColor3 = state and Color3.fromRGB(10, 10, 14) or Color3.fromRGB(200, 200, 210)
		btn.Text = "  " .. text .. " : " .. (state and "ON" or "OFF")
		callback(state)
	end)
	return btn
end

